# ============================================================
# 后端环境变量模板 —— 复制为 .env 并填写真实值
# .env 文件绝对不允许提交到 Git！
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# 格式：mysql+aiomysql://user:password@host:3306/dbname
DATABASE_URL=mysql+aiomysql://root:your_password@127.0.0.1:3306/traffic_detection

# ── JWT 认证 ─────────────────────────────────────────────────
# 生产环境必须使用至少 32 位随机字符串，禁止使用弱密钥
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── TCP 服务 ─────────────────────────────────────────────────
TCP_HOST=0.0.0.0
TCP_PORT=9000

# ── FastAPI 服务 ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── YOLO 推理 ─────────────────────────────────────────────────
# 相对于 backend/ 目录的路径
YOLO_MODEL_PATH=models/yolov8n.pt
# GPU 推理填 cuda:0，无 GPU 填 cpu
YOLO_DEVICE=cpu

# ── CORS ──────────────────────────────────────────────────────
# 多个 Origin 用英文逗号分隔
CORS_ORIGINS=http://localhost:5173

# ── 日志 ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 数据库连接池 ──────────────────────────────────────────────
DB_POOL_MIN=3
DB_POOL_MAX=10

# ── Cookie 安全（生产环境必须设为 true，需 HTTPS）──────────────
COOKIE_SECURE=false
COOKIE_DOMAIN=
