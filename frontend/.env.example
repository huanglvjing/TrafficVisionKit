# ============================================================
# 前端环境变量模板 —— 复制为 .env.local 并填写真实值
# .env.local 文件绝对不允许提交到 Git！
# ============================================================

# 后端 REST API 基地址（生产环境改为 https://）
VITE_API_BASE_URL=http://192.168.1.10:8000

# WebSocket 基地址（生产环境改为 wss://）
VITE_WS_BASE_URL=ws://192.168.1.10:8000

# 默认展示的设备 ID
VITE_DEFAULT_DEVICE_ID=1
